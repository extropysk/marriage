---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Hero from "../components/Hero.astro";
import Story from "../components/Story.astro";
import Journey from "../components/Journey.astro";
import Details from "../components/Details.astro";
import Schedule from "../components/Schedule.astro";
import WeddingParty from "../components/WeddingParty.astro";
import Gallery from "../components/Gallery.astro";
import Registry from "../components/Registry.astro";
import Rsvp from "../components/Rsvp.astro";
import Faq from "../components/Faq.astro";
import Contact from "../components/Contact.astro";
import Footer from "../components/Footer.astro";
import { useTranslations } from "../utils/i18n";
const t = useTranslations();
---

<Layout title={t("meta.title")}>
  <Header />
  <main>
    <Hero />
    <Story />
    <Journey />
    <Details />
    <Schedule />
    <WeddingParty />
    <Gallery />
    <Registry />
    <Rsvp />
    <Faq />
    <Contact />
  </main>
  <Footer />
</Layout>
