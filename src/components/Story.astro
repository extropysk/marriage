---
import { useTranslations } from "../utils/i18n";
const t = useTranslations();
const prefix = t("meta.prefix");
---

<section id="story" class="py-20 md:py-24 bg-white relative">
  <div class="max-w-7xl mx-auto px-4 relative">
    <div class="mb-16 text-center">
      <h2
        class="font-serif text-4xl md:text-5xl font-light text-botanical mb-6"
      >
        {t("story.heading")}
      </h2>
      <div
        class="w-40 h-0.5 bg-linear-to-r from-transparent via-sage to-transparent mx-auto mt-8"
      >
      </div>
    </div>

    <div class="grid lg:grid-cols-2 gap-12 items-center">
      <div class="relative overflow-hidden aspect-[4/2.75] group">
        <img
          src={`/${prefix}/img/story.jpg`}
          alt="How We Met"
          loading="lazy"
          class="relative px-3 w-full object-cover transition-transform duration-700 group-hover:scale-110"
        />
        <img
          src="/img/frame2.png"
          alt="frame"
          loading="lazy"
          class="absolute inset-0 pointer-events-none"
        />
      </div>

      <div class="relative space-y-12">
        <div class="flex flex-col">
          <h3
            class="font-serif text-4xl font-light text-botanical mb-4 flex items-center"
          >
            {t("story.howWeMet.title")}
          </h3>
          <p class="text-gray-600 leading-relaxed text-lg">
            {t("story.howWeMet.text")}
          </p>
        </div>
        <div class="flex flex-col">
          <h3
            class="font-serif text-4xl font-light text-botanical mb-4 flex items-center"
          >
            {t("story.proposal.title")}
          </h3>
          <p class="text-gray-600 leading-relaxed text-lg">
            {t("story.proposal.text")}
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
