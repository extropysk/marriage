---
---

<section id="contact" class="py-20 md:py-24 relative bg-ivory">
  <img src="/img/bottom-left-flower.png" alt="" loading="lazy" class="absolute bottom-0 left-0 opacity-50 pointer-events-none" />
  <img src="/img/bottom-right-flower.png" alt="" loading="lazy" class="absolute bottom-0 right-0 opacity-50 pointer-events-none" />

  <div class="max-w-7xl mx-auto px-4 relative">
    <div class="mb-16 text-center">
      <h2 class="font-serif text-4xl md:text-5xl font-light text-botanical mb-6">Get In Touch</h2>
      <div class="w-40 h-0.5 bg-linear-to-r from-transparent via-sage to-transparent mx-auto mt-8"></div>
      <p class="text-gray-600 mt-6 max-w-2xl mx-auto">Have questions? Need more information? Feel free to reach out to our wedding planner or contact us directly.</p>
    </div>

    <div class="max-w-4xl mx-auto grid md:grid-cols-2 gap-8 mb-16">
      <!-- Wedding Planner -->
      <div class="bg-white p-8 shadow-lg border border-mist text-center hover:shadow-xl transition-all">
        <div class="size-24 rounded-full overflow-hidden mx-auto mb-6">
          <img src="/img/planner.jpg" alt="Jennifer Rose Events" loading="lazy" class="w-full h-full object-cover" />
        </div>
        <h3 class="font-serif text-xl font-semibold text-botanical">Jennifer Rose Events</h3>
        <p class="text-sage text-sm mb-4">Wedding Planner</p>
        <div class="space-y-2">
          <a href="mailto:jennifer@roseevents.com" class="block text-gray-600 hover:text-botanical transition-colors">jennifer@roseevents.com</a>
          <a href="tel:+15035550123" class="block text-gray-600 hover:text-botanical transition-colors">(503) 555-0123</a>
        </div>
      </div>

      <!-- The Couple -->
      <div class="bg-white p-8 shadow-lg border border-mist text-center hover:shadow-xl transition-all">
        <div class="size-24 rounded-full overflow-hidden mx-auto mb-6">
          <img src="/img/gallery4.jpg" alt="Emma & Lucas" loading="lazy" class="w-full h-full object-cover" />
        </div>
        <h3 class="font-serif text-xl font-semibold text-botanical">Emma &amp; Lucas</h3>
        <p class="text-sage text-sm mb-4">The Couple</p>
        <div class="space-y-2">
          <a href="mailto:emmaandlucas2026@email.com" class="block text-gray-600 hover:text-botanical transition-colors">emmaandlucas2026@email.com</a>
          <p class="text-sm text-gray-500 mt-2">For day-of emergencies, please contact our wedding planner</p>
        </div>
      </div>
    </div>

    <!-- Social Media -->
    <div class="text-center">
      <p class="text-gray-600 mb-6">Follow our journey on social media</p>
      <div class="flex justify-center gap-6 mb-6">
        <a href="#" class="bg-botanical text-white w-12 h-12 rounded-full flex items-center justify-center hover:bg-sage transition-colors">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
        </a>
        <a href="#" class="bg-botanical text-white w-12 h-12 rounded-full flex items-center justify-center hover:bg-sage transition-colors">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
        </a>
        <a href="#" class="bg-botanical text-white w-12 h-12 rounded-full flex items-center justify-center hover:bg-sage transition-colors">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12.017 0C5.396 0 .029 5.367.029 11.987c0 5.079 3.158 9.417 7.618 11.162-.105-.949-.199-2.403.041-3.439.219-.937 1.406-5.957 1.406-5.957s-.359-.72-.359-1.781c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738a.36.36 0 01.083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.631-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.57 23.812 10.763 24 12.017 24c6.624 0 11.99-5.367 11.99-11.988C24.007 5.367 18.641.001 12.017.001z"/></svg>
        </a>
      </div>
      <p class="font-serif text-xl text-botanical">#EmmaAndLucasForever</p>
    </div>
  </div>
</section>
