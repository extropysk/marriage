---
import { useTranslations } from "../i18n";
const t = useTranslations();
---

<footer
  class="bg-botanical relative text-white py-16 bg-repeat"
  style="background-image: url('/img/bg-pattern.png');"
>
  <div class="absolute inset-0 bg-linear-to-b from-botanical/95 to-botanical">
  </div>
  <div class="relative z-10 max-w-7xl mx-auto px-4 text-center">
    <div class="font-serif text-4xl font-bold tracking-wide mb-8">
      <span>E</span>
      <span class="mx-2">&amp;</span>
      <span>L</span>
    </div>

    <nav class="flex flex-wrap justify-center gap-2 mb-8">
      <a
        href="#home"
        class="hover:text-yellow-400 transition-colors text-sm uppercase tracking-wider"
        >{t("footer.nav.home")}</a
      >
      <span class="text-white/40">&bull;</span>
      <a
        href="#story"
        class="hover:text-yellow-400 transition-colors text-sm uppercase tracking-wider"
        >{t("footer.nav.story")}</a
      >
      <span class="text-white/40">&bull;</span>
      <a
        href="#details"
        class="hover:text-yellow-400 transition-colors text-sm uppercase tracking-wider"
        >{t("footer.nav.details")}</a
      >
      <span class="text-white/40">&bull;</span>
      <a
        href="#rsvp"
        class="hover:text-yellow-400 transition-colors text-sm uppercase tracking-wider"
        >{t("footer.nav.rsvp")}</a
      >
    </nav>

    <p
      class="text-white/70 text-sm mb-4 flex items-center justify-center gap-2"
    >
      {t("footer.madeWith")}
      <svg class="w-4 h-4 text-red-400" fill="currentColor" viewBox="0 0 16 16"
        ><path
          fill-rule="evenodd"
          d="M8 1.314C12.438-3.248 23.534 4.735 8 15C-7.534 4.736 3.562-3.248 8 1.314"
        ></path></svg
      >
      {t("footer.madeFor")}
    </p>

    <p class="text-white/50 text-xs">{t("footer.copyright")}</p>
  </div>
</footer>

<!-- Back to Top Button -->
<button
  type="button"
  x-data="{ show: false }"
  x-on:scroll.window="show = (window.pageYOffset > 300)"
  x-show="show"
  x-transition:enter="transition ease-out duration-300"
  x-transition:enter-start="opacity-0 scale-90"
  x-transition:enter-end="opacity-100 scale-100"
  x-transition:leave="transition ease-in duration-200"
  x-transition:leave-start="opacity-100 scale-100"
  x-transition:leave-end="opacity-0 scale-90"
  x-on:click="window.scrollTo({ top: 0, behavior: 'smooth' })"
  aria-label="Back to top"
  class="fixed bottom-4 right-4 bg-botanical text-white size-10 flex items-center justify-center shadow-lg hover:bg-botanical/80 transition z-50"
  style="display: none;"
>
  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
    <path
      stroke-linecap="round"
      stroke-linejoin="round"
      stroke-width="2"
      d="M5 15l7-7 7 7"></path>
  </svg>
</button>
