---
import { useTranslations } from "../utils/i18n";
const t = useTranslations();

const ctaUrl = t("details.cta.url");
const ctaTarget = ctaUrl && ctaUrl[0] === "#" ? "_self" : "_blank";
---

<section id="details" class="py-20 md:py-24 bg-mist/50">
  <div
    class="max-w-7xl mx-auto px-4"
    x-data="{ showModal: false }"
    x-on:open-rundown.window="showModal = true"
  >
    <div class="mb-16 text-center">
      <h2
        class="font-serif text-4xl md:text-5xl font-light text-botanical mb-6"
      >
        {t("details.heading")}
      </h2>
      <div
        class="w-40 h-0.5 bg-linear-to-r from-transparent via-sage to-transparent mx-auto mt-8"
      >
      </div>
      <p class="text-gray-600 mt-6 max-w-2xl mx-auto">
        {t("details.subtitle")}
      </p>
    </div>

    <div class="grid md:grid-cols-2 gap-8 max-w-6xl mx-auto mb-20">
      <!-- Ceremony Card -->
      <div
        class="bg-white rounded-xl shadow-sm border border-mist overflow-hidden hover:shadow-2xl transition-all duration-300"
      >
        <div class="relative overflow-hidden group">
          <img
            src={t("details.ceremony.img")}
            alt={t("details.ceremony.title")}
            loading="lazy"
            class="w-full h-64 object-cover transition-transform duration-500 group-hover:scale-110"
          />
          <div
            class="absolute inset-0 bg-linear-to-t from-dark/80 via-botanical/50 to-transparent"
          >
          </div>
          <div class="absolute bottom-0 left-0 right-0 p-6 text-white">
            <div class="flex items-center gap-3 mb-2">
              <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 16 16"
                ><path
                  fill-rule="evenodd"
                  d="M8 1.314C12.438-3.248 23.534 4.735 8 15C-7.534 4.736 3.562-3.248 8 1.314"
                ></path></svg
              >
              <h3 class="font-serif text-4xl font-semibold">
                {t("details.ceremony.title")}
              </h3>
            </div>
            <p class="text-white/90 text-sm">{t("details.ceremony.tagline")}</p>
          </div>
        </div>
        <div class="p-8 space-y-5">
          <div class="flex items-start gap-4 pb-5 border-b border-mist">
            <div class="bg-sage/10 p-3 rounded-lg shrink-0">
              <svg
                class="w-6 h-6 text-sage"
                fill="currentColor"
                viewBox="0 0 16 16"
                ><path
                  d="M11 6.5a.5.5 0 0 1 .5-.5h1a.5.5 0 0 1 .5.5v1a.5.5 0 0 1-.5.5h-1a.5.5 0 0 1-.5-.5z"
                ></path><path
                  d="M3.5 0a.5.5 0 0 1 .5.5V1h8V.5a.5.5 0 0 1 1 0V1h1a2 2 0 0 1 2 2v11a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2V3a2 2 0 0 1 2-2h1V.5a.5.5 0 0 1 .5-.5M1 4v10a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1V4z"
                ></path></svg
              >
            </div>
            <div>
              <p
                class="text-xs uppercase tracking-wider text-sage font-semibold mb-1"
              >
                {t("details.labels.date")}
              </p>
              <p class="text-lg font-semibold text-botanical">
                {t("details.ceremony.date")}
              </p>
              <p class="text-sm text-gray-500 mt-1">
                {t("details.ceremony.dateNote")}
              </p>
            </div>
          </div>
          <div class="flex items-start gap-4 pb-5 border-b border-mist">
            <div class="bg-sage/10 p-3 rounded-lg shrink-0">
              <svg
                class="w-6 h-6 text-sage"
                fill="currentColor"
                viewBox="0 0 16 16"
                ><path
                  d="M8 3.5a.5.5 0 0 0-1 0V9a.5.5 0 0 0 .252.434l3.5 2a.5.5 0 0 0 .496-.868L8 8.71z"
                ></path><path
                  d="M8 16A8 8 0 1 0 8 0a8 8 0 0 0 0 16m7-8A7 7 0 1 1 1 8a7 7 0 0 1 14 0"
                ></path></svg
              >
            </div>
            <div>
              <p
                class="text-xs uppercase tracking-wider text-sage font-semibold mb-1"
              >
                {t("details.labels.time")}
              </p>
              <p class="text-lg font-semibold text-botanical">
                {t("details.ceremony.time")}
              </p>
              <p class="text-sm text-gray-500 mt-1">
                {t("details.ceremony.timeNote")}
              </p>
            </div>
          </div>
          <div class="flex items-start gap-4 pb-5 border-b border-mist">
            <div class="bg-sage/10 p-3 rounded-lg shrink-0">
              <svg
                class="w-6 h-6 text-sage"
                fill="currentColor"
                viewBox="0 0 16 16"
                ><path
                  d="M8 16s6-5.686 6-10A6 6 0 0 0 2 6c0 4.314 6 10 6 10m0-7a3 3 0 1 1 0-6a3 3 0 0 1 0 6"
                ></path></svg
              >
            </div>
            <div>
              <p
                class="text-xs uppercase tracking-wider text-sage font-semibold mb-1"
              >
                {t("details.labels.venue")}
              </p>
              <p class="text-lg font-semibold text-botanical">
                {t("details.ceremony.venue")}
              </p>
              <p class="text-gray-600 mt-2">
                {t("details.ceremony.addressLine1")}<br />{
                  t("details.ceremony.addressLine2")
                }
              </p>
            </div>
          </div>
          <div class="flex items-start gap-4 pb-5 border-b border-mist">
            <div class="bg-sage/10 p-3 rounded-lg shrink-0">
              <svg
                class="w-6 h-6 text-sage"
                fill="currentColor"
                viewBox="0 0 16 16"
                ><path
                  d="M15 12a1 1 0 0 1-1 1H2a1 1 0 0 1-1-1V6a1 1 0 0 1 1-1h1.172a3 3 0 0 0 2.12-.879l.83-.828A1 1 0 0 1 6.827 3h2.344a1 1 0 0 1 .707.293l.828.828A3 3 0 0 0 12.828 5H14a1 1 0 0 1 1 1zM2 4a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V6a2 2 0 0 0-2-2h-1.172a2 2 0 0 1-1.414-.586l-.828-.828A2 2 0 0 0 9.172 2H6.828a2 2 0 0 0-1.414.586l-.828.828A2 2 0 0 1 3.172 4z"
                ></path><path
                  d="M8 11a2.5 2.5 0 1 1 0-5 2.5 2.5 0 0 1 0 5m0 1a3.5 3.5 0 1 0 0-7 3.5 3.5 0 0 0 0 7M3 6.5a.5.5 0 1 1-1 0 .5.5 0 0 1 1 0"
                ></path></svg
              >
            </div>
            <div>
              <p
                class="text-xs uppercase tracking-wider text-sage font-semibold mb-1"
              >
                {t("details.labels.photo")}
              </p>
              <p class="text-lg font-semibold text-botanical">
                {t("details.ceremony.photo")}
              </p>
              <p class="text-sm text-gray-500 mt-1">
                {t("details.ceremony.photoNote")}
              </p>
            </div>
          </div>
          <div class="mt-8 flex gap-3">
            <a
              href={t("details.ceremony.btnDirections")}
              target="_blank"
              class="flex items-center gap-2 border-2 border-botanical text-botanical px-6 py-3 rounded-lg hover:bg-botanical hover:text-white transition-all"
            >
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 16 16"
                ><path
                  fill-rule="evenodd"
                  d="M15.817.113A.5.5 0 0 1 16 .5v14a.5.5 0 0 1-.402.49l-5 1a.5.5 0 0 1-.196 0L5.5 15.01l-4.902.98A.5.5 0 0 1 0 15.5v-14a.5.5 0 0 1 .402-.49l5-1a.5.5 0 0 1 .196 0L10.5.99l4.902-.98a.5.5 0 0 1 .415.103M10 1.91l-4-.8v12.98l4 .8zm1 12.98l4-.8V1.11l-4 .8zm-6-.8V1.11l-4 .8v12.98z"
                ></path></svg
              >
              {t("details.btnDirections")}
            </a>
            {
              !t("details.timeline.hidden") && (
                <button
                  x-on:click="$dispatch('open-rundown')"
                  class="flex items-center py-3 px-6 bg-botanical text-white gap-2 rounded-lg hover:bg-botanical/90"
                >
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 16 16">
                    <path d="M15.854.146a.5.5 0 0 1 .11.54l-5.819 14.547a.75.75 0 0 1-1.329.124l-3.178-4.995L.643 7.184a.75.75 0 0 1 .124-1.33L15.314.037a.5.5 0 0 1 .54.11ZM6.636 10.07l2.761 4.338L14.13 2.576zm6.787-8.201L1.591 6.602l4.339 2.76z" />
                  </svg>
                  {t("details.btnRundown")}
                </button>
              )
            }
          </div>
        </div>
      </div>

      <!-- Reception Card -->
      <div
        class="bg-white rounded-xl shadow-sm border border-mist overflow-hidden hover:shadow-2xl transition-all duration-300"
      >
        <div class="relative overflow-hidden group">
          <img
            src={t("details.reception.img")}
            alt={t("details.reception.title")}
            loading="lazy"
            class="w-full h-64 object-cover transition-transform duration-500 group-hover:scale-110"
          />
          <div
            class="absolute inset-0 bg-linear-to-t from-dark/80 via-botanical/50 to-transparent"
          >
          </div>
          <div class="absolute bottom-0 left-0 right-0 p-6 text-white">
            <div class="flex items-center gap-3 mb-2">
              <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 16 16"
                ><path
                  d="M7.657 6.247c.11-.33.576-.33.686 0l.645 1.937a2.89 2.89 0 0 0 1.829 1.828l1.936.645c.33.11.33.576 0 .686l-1.937.645a2.89 2.89 0 0 0-1.828 1.829l-.645 1.936a.361.361 0 0 1-.686 0l-.645-1.937a2.89 2.89 0 0 0-1.828-1.828l-1.937-.645a.361.361 0 0 1 0-.686l1.937-.645a2.89 2.89 0 0 0 1.828-1.828zM3.794 1.148a.217.217 0 0 1 .412 0l.387 1.162c.173.518.579.924 1.097 1.097l1.162.387a.217.217 0 0 1 0 .412l-1.162.387A1.73 1.73 0 0 0 4.593 5.69l-.387 1.162a.217.217 0 0 1-.412 0L3.407 5.69A1.73 1.73 0 0 0 2.31 4.593l-1.162-.387a.217.217 0 0 1 0-.412l1.162-.387A1.73 1.73 0 0 0 3.407 2.31zM10.863.099a.145.145 0 0 1 .274 0l.258.774c.115.346.386.617.732.732l.774.258a.145.145 0 0 1 0 .274l-.774.258a1.16 1.16 0 0 0-.732.732l-.258.774a.145.145 0 0 1-.274 0l-.258-.774a1.16 1.16 0 0 0-.732-.732L9.1 2.137a.145.145 0 0 1 0-.274l.774-.258c.346-.115.617-.386.732-.732z"
                ></path></svg
              >
              <h3 class="font-serif text-4xl font-semibold">
                {t("details.reception.title")}
              </h3>
            </div>
            <p class="text-white/90 text-sm">
              {t("details.reception.tagline")}
            </p>
          </div>
        </div>
        <div class="p-8 space-y-5">
          <div class="flex items-start gap-4 pb-5 border-b border-mist">
            <div class="bg-sage/10 p-3 rounded-lg shrink-0">
              <svg
                class="w-6 h-6 text-sage"
                fill="currentColor"
                viewBox="0 0 16 16"
                ><path
                  d="M11 6.5a.5.5 0 0 1 .5-.5h1a.5.5 0 0 1 .5.5v1a.5.5 0 0 1-.5.5h-1a.5.5 0 0 1-.5-.5z"
                ></path><path
                  d="M3.5 0a.5.5 0 0 1 .5.5V1h8V.5a.5.5 0 0 1 1 0V1h1a2 2 0 0 1 2 2v11a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2V3a2 2 0 0 1 2-2h1V.5a.5.5 0 0 1 .5-.5M1 4v10a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1V4z"
                ></path></svg
              >
            </div>
            <div>
              <p
                class="text-xs uppercase tracking-wider text-sage font-semibold mb-1"
              >
                {t("details.labels.date")}
              </p>
              <p class="text-lg font-semibold text-botanical">
                {t("details.reception.date")}
              </p>
              <p class="text-sm text-gray-500 mt-1">
                {t("details.reception.dateNote")}
              </p>
            </div>
          </div>
          <div class="flex items-start gap-4 pb-5 border-b border-mist">
            <div class="bg-sage/10 p-3 rounded-lg shrink-0">
              <svg
                class="w-6 h-6 text-sage"
                fill="currentColor"
                viewBox="0 0 16 16"
                ><path
                  d="M8 3.5a.5.5 0 0 0-1 0V9a.5.5 0 0 0 .252.434l3.5 2a.5.5 0 0 0 .496-.868L8 8.71z"
                ></path><path
                  d="M8 16A8 8 0 1 0 8 0a8 8 0 0 0 0 16m7-8A7 7 0 1 1 1 8a7 7 0 0 1 14 0"
                ></path></svg
              >
            </div>
            <div>
              <p
                class="text-xs uppercase tracking-wider text-sage font-semibold mb-1"
              >
                {t("details.labels.time")}
              </p>
              <p class="text-lg font-semibold text-botanical">
                {t("details.reception.time")}
              </p>
              <p class="text-sm text-gray-500 mt-1">
                {t("details.reception.timeNote")}
              </p>
            </div>
          </div>
          <div class="flex items-start gap-4 pb-5 border-b border-mist">
            <div class="bg-sage/10 p-3 rounded-lg shrink-0">
              <svg
                class="w-6 h-6 text-sage"
                fill="currentColor"
                viewBox="0 0 16 16"
                ><path
                  d="M8 16s6-5.686 6-10A6 6 0 0 0 2 6c0 4.314 6 10 6 10m0-7a3 3 0 1 1 0-6a3 3 0 0 1 0 6"
                ></path></svg
              >
            </div>
            <div>
              <p
                class="text-xs uppercase tracking-wider text-sage font-semibold mb-1"
              >
                {t("details.labels.venue")}
              </p>
              <p class="text-lg font-semibold text-botanical">
                {t("details.reception.venue")}
              </p>
              <p class="text-gray-600 mt-2">
                {t("details.reception.addressLine1")}<br />{
                  t("details.reception.addressLine2")
                }
              </p>
            </div>
          </div>
          <div class="flex items-start gap-4 pb-5 border-b border-mist">
            <div class="bg-sage/10 p-3 rounded-lg shrink-0">
              <svg
                class="w-6 h-6 text-sage"
                fill="currentColor"
                viewBox="0 0 16 16"
                ><path
                  d="M6 13c0 1.105-1.12 2-2.5 2S1 14.105 1 13s1.12-2 2.5-2s2.5.896 2.5 2m9-2c0 1.105-1.12 2-2.5 2s-2.5-.895-2.5-2s1.12-2 2.5-2s2.5.895 2.5 2"
                ></path><path fill-rule="evenodd" d="M14 11V2h1v9zM6 3v10H5V3z"
                ></path><path
                  d="M5 2.905a1 1 0 0 1 .9-.995l8-.8a1 1 0 0 1 1.1.995V3L5 4z"
                ></path></svg
              >
            </div>
            <div>
              <p
                class="text-xs uppercase tracking-wider text-sage font-semibold mb-1"
              >
                {t("details.labels.entertainment")}
              </p>
              <p class="text-lg font-semibold text-botanical">
                {t("details.reception.entertainment")}
              </p>
              <p class="text-sm text-gray-500 mt-1">
                {t("details.reception.entertainmentNote")}
              </p>
            </div>
          </div>
          <div class="mt-8 flex gap-3">
            <a
              href={t("details.reception.btnDirections")}
              target="_blank"
              class="flex items-center gap-2 border-2 border-botanical text-botanical px-6 py-3 rounded-lg hover:bg-botanical hover:text-white transition-all"
            >
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 16 16"
                ><path
                  fill-rule="evenodd"
                  d="M15.817.113A.5.5 0 0 1 16 .5v14a.5.5 0 0 1-.402.49l-5 1a.5.5 0 0 1-.196 0L5.5 15.01l-4.902.98A.5.5 0 0 1 0 15.5v-14a.5.5 0 0 1 .402-.49l5-1a.5.5 0 0 1 .196 0L10.5.99l4.902-.98a.5.5 0 0 1 .415.103M10 1.91l-4-.8v12.98l4 .8zm1 12.98l4-.8V1.11l-4 .8zm-6-.8V1.11l-4 .8v12.98z"
                ></path></svg
              >
              {t("details.btnDirections")}
            </a>
            {
              !t("details.timeline.hidden") && (
                <button
                  x-on:click="$dispatch('open-rundown')"
                  class="flex items-center py-3 px-6 bg-botanical text-white gap-2 rounded-lg hover:bg-botanical/90"
                >
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 16 16">
                    <path d="M15.854.146a.5.5 0 0 1 .11.54l-5.819 14.547a.75.75 0 0 1-1.329.124l-3.178-4.995L.643 7.184a.75.75 0 0 1 .124-1.33L15.314.037a.5.5 0 0 1 .54.11ZM6.636 10.07l2.761 4.338L14.13 2.576zm6.787-8.201L1.591 6.602l4.339 2.76z" />
                  </svg>
                  {t("details.btnRundown")}
                </button>
              )
            }
          </div>
        </div>
      </div>
    </div>

    <!-- Rundown Modal -->
    <div
      x-show="showModal"
      x-cloak
      x-on:click="showModal = false"
      class="fixed inset-0 z-50 flex items-center justify-center bg-black/60 p-4 backdrop-blur-sm"
    >
      <div
        x-on:click.stop
        class="bg-white p-10 max-w-5xl w-full rounded-xl shadow-2xl max-h-[90vh] overflow-y-auto relative"
      >
        <button
          x-on:click="showModal = false"
          class="absolute top-4 right-4 w-10 h-10 flex items-center justify-center rounded-full bg-sage/10 hover:bg-sage/20"
        >
          <svg
            class="w-5 h-5 text-botanical"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
            ><path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M6 18L18 6M6 6l12 12"></path></svg
          >
        </button>
        <div class="text-center mb-10">
          <svg
            class="w-10 h-10 text-sage mx-auto mb-3"
            fill="currentColor"
            viewBox="0 0 16 16"
            ><path
              d="M8 3.5a.5.5 0 0 0-1 0V9a.5.5 0 0 0 .252.434l3.5 2a.5.5 0 0 0 .496-.868L8 8.71z"
            ></path><path
              d="M8 16A8 8 0 1 0 8 0a8 8 0 0 0 0 16m7-8A7 7 0 1 1 1 8a7 7 0 0 1 14 0"
            ></path></svg
          >
          <h3 class="font-serif text-3xl font-semibold text-botanical">
            {t("details.timeline.heading")}
          </h3>
          <p class="text-gray-600 mt-2">{t("details.timeline.subtitle")}</p>
        </div>
        <div class="space-y-6">
          {
            t("details.timeline.items").map((item) => (
              <div class="flex items-start gap-6">
                <div class="bg-sage text-white rounded-full w-16 h-16 flex items-center justify-center font-semibold shadow-lg text-center text-sm">
                  {item.time}
                  <br />
                  <span class="text-xs">{item.period}</span>
                </div>
                <div class="bg-mist/30 p-5 rounded-lg flex-1">
                  <h4 class="font-semibold text-botanical text-lg">
                    {item.title}
                  </h4>
                  <p class="text-gray-600">{item.desc}</p>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </div>

    <!-- Important Information -->
    {
      !t("details.info.hidden") && (
        <div class="max-w-6xl mx-auto">
          <div class="text-center mb-12">
            <h3 class="font-serif text-4xl font-semibold text-botanical">
              {t("details.info.heading")}
            </h3>
            <p class="text-gray-600 mt-4">{t("details.info.subtitle")}</p>
          </div>
          <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
            {t("details.info.items").map((item) => (
              <div class="flex items-start gap-4 p-5 rounded-lg shadow-sm hover:shadow-lg hover:-translate-y-1 transition-all bg-white">
                <div class="bg-sage/10 p-3 rounded-lg shrink-0">
                  <svg
                    class="w-6 h-6 text-sage"
                    fill="currentColor"
                    viewBox="0 0 16 16"
                  >
                    <path d="M8 1.314C12.438-3.248 23.534 4.735 8 15C-7.534 4.736 3.562-3.248 8 1.314" />
                  </svg>
                </div>
                <div>
                  <h4 class="font-semibold text-botanical">{item.title}</h4>
                  <p class="text-gray-600 text-sm mt-1">{item.text}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      )
    }

    <!-- CTA -->
    <div
      class="max-w-6xl mx-auto mt-20 text-center bg-white rounded-2xl shadow-sm border border-mist px-8 py-12"
    >
      <h3 class="font-serif text-4xl font-light text-botanical mb-4">
        {t("details.cta.heading")}
      </h3>
      <p class="text-gray-600 mb-8 max-w-xl mx-auto">
        {t("details.cta.subtitle")}
      </p>
      <a
        href={ctaUrl}
        target={ctaTarget}
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 bg-botanical text-white px-8 py-4 rounded-lg text-lg hover:bg-botanical/90 transition-colors"
      >
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 16 16">
          <path
            d="M14 1a1 1 0 0 1 1 1v8a1 1 0 0 1-1 1H4.414A2 2 0 0 0 3 11.586l-2 2V2a1 1 0 0 1 1-1zM2 0a2 2 0 0 0-2 2v12.793a.5.5 0 0 0 .854.353l2.853-2.853A1 1 0 0 1 4.414 12H14a2 2 0 0 0 2-2V2a2 2 0 0 0-2-2z"
          ></path>
        </svg>
        {t("details.cta.btn")}
      </a>
    </div>
  </div>
</section>
