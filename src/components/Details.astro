---
---

<section id="details" class="py-20 md:py-24 bg-mist/50">
  <div class="max-w-7xl mx-auto px-4" x-data="{ showModal: false }" x-on:open-rundown.window="showModal = true">
    <div class="mb-16 text-center">
      <h2 class="font-serif text-4xl md:text-5xl font-light text-botanical mb-6">Wedding Details</h2>
      <div class="w-40 h-0.5 bg-linear-to-r from-transparent via-sage to-transparent mx-auto mt-8"></div>
      <p class="text-gray-600 mt-6 max-w-2xl mx-auto">Join us for a day of celebration filled with love, laughter, and unforgettable memories</p>
    </div>

    <div class="grid md:grid-cols-2 gap-8 max-w-6xl mx-auto mb-20">
      <!-- Ceremony Card -->
      <div class="bg-white rounded-xl shadow-sm border border-mist overflow-hidden hover:shadow-2xl transition-all duration-300">
        <div class="relative overflow-hidden group">
          <img src="/img/hero.jpg" alt="Rose Garden" loading="lazy" class="w-full h-64 object-cover transition-transform duration-500 group-hover:scale-110" />
          <div class="absolute inset-0 bg-linear-to-t from-dark/80 via-botanical/50 to-transparent"></div>
          <div class="absolute bottom-0 left-0 right-0 p-6 text-white">
            <div class="flex items-center gap-3 mb-2">
              <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 16 16"><path fill-rule="evenodd" d="M8 1.314C12.438-3.248 23.534 4.735 8 15C-7.534 4.736 3.562-3.248 8 1.314"/></svg>
              <h3 class="font-serif text-4xl font-semibold">Ceremony</h3>
            </div>
            <p class="text-white/90 text-sm">Where two hearts become one</p>
          </div>
        </div>
        <div class="p-8 space-y-5">
          <div class="flex items-start gap-4 pb-5 border-b border-mist">
            <div class="bg-sage/10 p-3 rounded-lg shrink-0">
              <svg class="w-6 h-6 text-sage" fill="currentColor" viewBox="0 0 16 16"><path d="M11 6.5a.5.5 0 0 1 .5-.5h1a.5.5 0 0 1 .5.5v1a.5.5 0 0 1-.5.5h-1a.5.5 0 0 1-.5-.5z"/><path d="M3.5 0a.5.5 0 0 1 .5.5V1h8V.5a.5.5 0 0 1 1 0V1h1a2 2 0 0 1 2 2v11a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2V3a2 2 0 0 1 2-2h1V.5a.5.5 0 0 1 .5-.5M1 4v10a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1V4z"/></svg>
            </div>
            <div>
              <p class="text-xs uppercase tracking-wider text-sage font-semibold mb-1">Date</p>
              <p class="text-lg font-semibold text-botanical">Saturday, June 15, 2026</p>
              <p class="text-sm text-gray-500 mt-1">Summer Season</p>
            </div>
          </div>
          <div class="flex items-start gap-4 pb-5 border-b border-mist">
            <div class="bg-sage/10 p-3 rounded-lg shrink-0">
              <svg class="w-6 h-6 text-sage" fill="currentColor" viewBox="0 0 16 16"><path d="M8 3.5a.5.5 0 0 0-1 0V9a.5.5 0 0 0 .252.434l3.5 2a.5.5 0 0 0 .496-.868L8 8.71z"/><path d="M8 16A8 8 0 1 0 8 0a8 8 0 0 0 0 16m7-8A7 7 0 1 1 1 8a7 7 0 0 1 14 0"/></svg>
            </div>
            <div>
              <p class="text-xs uppercase tracking-wider text-sage font-semibold mb-1">Time</p>
              <p class="text-lg font-semibold text-botanical">4:00 PM</p>
              <p class="text-sm text-gray-500 mt-1">Please arrive 15 minutes early</p>
            </div>
          </div>
          <div class="flex items-start gap-4 pb-5 border-b border-mist">
            <div class="bg-sage/10 p-3 rounded-lg shrink-0">
              <svg class="w-6 h-6 text-sage" fill="currentColor" viewBox="0 0 16 16"><path d="M8 16s6-5.686 6-10A6 6 0 0 0 2 6c0 4.314 6 10 6 10m0-7a3 3 0 1 1 0-6a3 3 0 0 1 0 6"/></svg>
            </div>
            <div>
              <p class="text-xs uppercase tracking-wider text-sage font-semibold mb-1">Venue</p>
              <p class="text-lg font-semibold text-botanical">Rose Garden Estate</p>
              <p class="text-gray-600 mt-2">1234 Bloom Street<br/>Portland, OR 97201</p>
            </div>
          </div>
          <div class="flex items-start gap-4 pb-5 border-b border-mist">
            <div class="bg-sage/10 p-3 rounded-lg shrink-0">
              <svg class="w-6 h-6 text-sage" fill="currentColor" viewBox="0 0 16 16"><path d="M2.5 15a.5.5 0 1 1 0-1h1v-1a4.5 4.5 0 0 1 2.557-4.06c.29-.139.443-.377.443-.59v-.7c0-.213-.154-.451-.443-.59A4.5 4.5 0 0 1 3.5 3V2h-1a.5.5 0 0 1 0-1h11a.5.5 0 0 1 0 1h-1v1a4.5 4.5 0 0 1-2.557 4.06c-.29.139-.443.377-.443.59v.7c0 .213.154.451.443.59A4.5 4.5 0 0 1 12.5 13v1h1a.5.5 0 0 1 0 1z"/></svg>
            </div>
            <div>
              <p class="text-xs uppercase tracking-wider text-sage font-semibold mb-1">Duration</p>
              <p class="text-lg font-semibold text-botanical">45 minutes</p>
              <p class="text-sm text-gray-500 mt-1">Outdoor garden ceremony</p>
            </div>
          </div>
          <div class="mt-8 flex gap-3">
            <a href="https://maps.google.com" target="_blank" class="flex items-center py-3 px-6 bg-botanical text-white gap-2 rounded-lg hover:bg-botanical/90">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 16 16"><path fill-rule="evenodd" d="M15.817.113A.5.5 0 0 1 16 .5v14a.5.5 0 0 1-.402.49l-5 1a.5.5 0 0 1-.196 0L5.5 15.01l-4.902.98A.5.5 0 0 1 0 15.5v-14a.5.5 0 0 1 .402-.49l5-1a.5.5 0 0 1 .196 0L10.5.99l4.902-.98a.5.5 0 0 1 .415.103M10 1.91l-4-.8v12.98l4 .8zm1 12.98l4-.8V1.11l-4 .8zm-6-.8V1.11l-4 .8v12.98z"/></svg>
              Get Directions
            </a>
            <button x-on:click="$dispatch('open-rundown')" class="flex items-center gap-2 border-2 border-botanical text-botanical px-6 py-3 rounded-lg hover:bg-botanical hover:text-white transition-all">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 16 16"><path d="M15.854.146a.5.5 0 0 1 .11.54l-5.819 14.547a.75.75 0 0 1-1.329.124l-3.178-4.995L.643 7.184a.75.75 0 0 1 .124-1.33L15.314.037a.5.5 0 0 1 .54.11ZM6.636 10.07l2.761 4.338L14.13 2.576zm6.787-8.201L1.591 6.602l4.339 2.76z"/></svg>
              Rundown
            </button>
          </div>
        </div>
      </div>

      <!-- Reception Card -->
      <div class="bg-white rounded-xl shadow-sm border border-mist overflow-hidden hover:shadow-2xl transition-all duration-300">
        <div class="relative overflow-hidden group">
          <img src="/img/ballroom.jpg" alt="Grand Ballroom" loading="lazy" class="w-full h-64 object-cover transition-transform duration-500 group-hover:scale-110" />
          <div class="absolute inset-0 bg-linear-to-t from-dark/80 via-botanical/50 to-transparent"></div>
          <div class="absolute bottom-0 left-0 right-0 p-6 text-white">
            <div class="flex items-center gap-3 mb-2">
              <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 16 16"><path d="M7.657 6.247c.11-.33.576-.33.686 0l.645 1.937a2.89 2.89 0 0 0 1.829 1.828l1.936.645c.33.11.33.576 0 .686l-1.937.645a2.89 2.89 0 0 0-1.828 1.829l-.645 1.936a.361.361 0 0 1-.686 0l-.645-1.937a2.89 2.89 0 0 0-1.828-1.828l-1.937-.645a.361.361 0 0 1 0-.686l1.937-.645a2.89 2.89 0 0 0 1.828-1.828zM3.794 1.148a.217.217 0 0 1 .412 0l.387 1.162c.173.518.579.924 1.097 1.097l1.162.387a.217.217 0 0 1 0 .412l-1.162.387A1.73 1.73 0 0 0 4.593 5.69l-.387 1.162a.217.217 0 0 1-.412 0L3.407 5.69A1.73 1.73 0 0 0 2.31 4.593l-1.162-.387a.217.217 0 0 1 0-.412l1.162-.387A1.73 1.73 0 0 0 3.407 2.31zM10.863.099a.145.145 0 0 1 .274 0l.258.774c.115.346.386.617.732.732l.774.258a.145.145 0 0 1 0 .274l-.774.258a1.16 1.16 0 0 0-.732.732l-.258.774a.145.145 0 0 1-.274 0l-.258-.774a1.16 1.16 0 0 0-.732-.732L9.1 2.137a.145.145 0 0 1 0-.274l.774-.258c.346-.115.617-.386.732-.732z"/></svg>
              <h3 class="font-serif text-4xl font-semibold">Reception</h3>
            </div>
            <p class="text-white/90 text-sm">Celebrate with us in elegance</p>
          </div>
        </div>
        <div class="p-8 space-y-5">
          <div class="flex items-start gap-4 pb-5 border-b border-mist">
            <div class="bg-sage/10 p-3 rounded-lg shrink-0">
              <svg class="w-6 h-6 text-sage" fill="currentColor" viewBox="0 0 16 16"><path d="M11 6.5a.5.5 0 0 1 .5-.5h1a.5.5 0 0 1 .5.5v1a.5.5 0 0 1-.5.5h-1a.5.5 0 0 1-.5-.5z"/><path d="M3.5 0a.5.5 0 0 1 .5.5V1h8V.5a.5.5 0 0 1 1 0V1h1a2 2 0 0 1 2 2v11a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2V3a2 2 0 0 1 2-2h1V.5a.5.5 0 0 1 .5-.5M1 4v10a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1V4z"/></svg>
            </div>
            <div>
              <p class="text-xs uppercase tracking-wider text-sage font-semibold mb-1">Date</p>
              <p class="text-lg font-semibold text-botanical">Saturday, June 15, 2026</p>
              <p class="text-sm text-gray-500 mt-1">Same evening celebration</p>
            </div>
          </div>
          <div class="flex items-start gap-4 pb-5 border-b border-mist">
            <div class="bg-sage/10 p-3 rounded-lg shrink-0">
              <svg class="w-6 h-6 text-sage" fill="currentColor" viewBox="0 0 16 16"><path d="M8 3.5a.5.5 0 0 0-1 0V9a.5.5 0 0 0 .252.434l3.5 2a.5.5 0 0 0 .496-.868L8 8.71z"/><path d="M8 16A8 8 0 1 0 8 0a8 8 0 0 0 0 16m7-8A7 7 0 1 1 1 8a7 7 0 0 1 14 0"/></svg>
            </div>
            <div>
              <p class="text-xs uppercase tracking-wider text-sage font-semibold mb-1">Time</p>
              <p class="text-lg font-semibold text-botanical">6:30 PM – 11:30 PM</p>
              <p class="text-sm text-gray-500 mt-1">Cocktail hour starts at 6:30 PM</p>
            </div>
          </div>
          <div class="flex items-start gap-4 pb-5 border-b border-mist">
            <div class="bg-sage/10 p-3 rounded-lg shrink-0">
              <svg class="w-6 h-6 text-sage" fill="currentColor" viewBox="0 0 16 16"><path d="M8 16s6-5.686 6-10A6 6 0 0 0 2 6c0 4.314 6 10 6 10m0-7a3 3 0 1 1 0-6a3 3 0 0 1 0 6"/></svg>
            </div>
            <div>
              <p class="text-xs uppercase tracking-wider text-sage font-semibold mb-1">Venue</p>
              <p class="text-lg font-semibold text-botanical">The Grand Ballroom</p>
              <p class="text-gray-600 mt-2">5678 Celebration Ave<br/>Portland, OR 97202</p>
            </div>
          </div>
          <div class="flex items-start gap-4 pb-5 border-b border-mist">
            <div class="bg-sage/10 p-3 rounded-lg shrink-0">
              <svg class="w-6 h-6 text-sage" fill="currentColor" viewBox="0 0 16 16"><path d="M6 13c0 1.105-1.12 2-2.5 2S1 14.105 1 13s1.12-2 2.5-2s2.5.896 2.5 2m9-2c0 1.105-1.12 2-2.5 2s-2.5-.895-2.5-2s1.12-2 2.5-2s2.5.895 2.5 2"/><path fill-rule="evenodd" d="M14 11V2h1v9zM6 3v10H5V3z"/><path d="M5 2.905a1 1 0 0 1 .9-.995l8-.8a1 1 0 0 1 1.1.995V3L5 4z"/></svg>
            </div>
            <div>
              <p class="text-xs uppercase tracking-wider text-sage font-semibold mb-1">Entertainment</p>
              <p class="text-lg font-semibold text-botanical">Live Band &amp; DJ</p>
              <p class="text-sm text-gray-500 mt-1">Dinner, dancing &amp; celebration</p>
            </div>
          </div>
          <div class="mt-8 flex gap-3">
            <a href="https://maps.google.com" target="_blank" class="flex items-center py-3 px-6 bg-botanical text-white gap-2 rounded-lg hover:bg-botanical/90">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 16 16"><path fill-rule="evenodd" d="M15.817.113A.5.5 0 0 1 16 .5v14a.5.5 0 0 1-.402.49l-5 1a.5.5 0 0 1-.196 0L5.5 15.01l-4.902.98A.5.5 0 0 1 0 15.5v-14a.5.5 0 0 1 .402-.49l5-1a.5.5 0 0 1 .196 0L10.5.99l4.902-.98a.5.5 0 0 1 .415.103M10 1.91l-4-.8v12.98l4 .8zm1 12.98l4-.8V1.11l-4 .8zm-6-.8V1.11l-4 .8v12.98z"/></svg>
              Get Directions
            </a>
            <button x-on:click="$dispatch('open-rundown')" class="flex items-center gap-2 border-2 border-botanical text-botanical px-6 py-3 rounded-lg hover:bg-botanical hover:text-white transition-all">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 16 16"><path d="M15.854.146a.5.5 0 0 1 .11.54l-5.819 14.547a.75.75 0 0 1-1.329.124l-3.178-4.995L.643 7.184a.75.75 0 0 1 .124-1.33L15.314.037a.5.5 0 0 1 .54.11ZM6.636 10.07l2.761 4.338L14.13 2.576zm6.787-8.201L1.591 6.602l4.339 2.76z"/></svg>
              Rundown
            </button>
          </div>
        </div>
      </div>
    </div>

    <!-- Rundown Modal -->
    <div x-show="showModal" x-cloak x-on:click="showModal = false" class="fixed inset-0 z-50 flex items-center justify-center bg-black/60 p-4 backdrop-blur-sm">
      <div x-on:click.stop class="bg-white p-10 max-w-5xl w-full rounded-xl shadow-2xl max-h-[90vh] overflow-y-auto relative">
        <button x-on:click="showModal = false" class="absolute top-4 right-4 w-10 h-10 flex items-center justify-center rounded-full bg-sage/10 hover:bg-sage/20">
          <svg class="w-5 h-5 text-botanical" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
        </button>
        <div class="text-center mb-10">
          <svg class="w-10 h-10 text-sage mx-auto mb-3" fill="currentColor" viewBox="0 0 16 16"><path d="M8 3.5a.5.5 0 0 0-1 0V9a.5.5 0 0 0 .252.434l3.5 2a.5.5 0 0 0 .496-.868L8 8.71z"/><path d="M8 16A8 8 0 1 0 8 0a8 8 0 0 0 0 16m7-8A7 7 0 1 1 1 8a7 7 0 0 1 14 0"/></svg>
          <h3 class="font-serif text-3xl font-semibold text-botanical">Day Timeline</h3>
          <p class="text-gray-600 mt-2">Here's how our special day will unfold</p>
        </div>
        <div class="space-y-6">
          <div class="flex items-start gap-6">
            <div class="bg-sage text-white rounded-full w-16 h-16 flex items-center justify-center font-semibold shadow-lg text-center text-sm">3:45<br/><span class="text-xs">PM</span></div>
            <div class="bg-mist/30 p-5 rounded-lg flex-1">
              <h4 class="font-semibold text-botanical text-lg">Guest Arrival</h4>
              <p class="text-gray-600">Please arrive and find your seats at Rose Garden Estate</p>
            </div>
          </div>
          <div class="flex items-start gap-6">
            <div class="bg-sage text-white rounded-full w-16 h-16 flex items-center justify-center font-semibold shadow-lg text-center text-sm">4:00<br/><span class="text-xs">PM</span></div>
            <div class="bg-mist/30 p-5 rounded-lg flex-1">
              <h4 class="font-semibold text-botanical text-lg">Ceremony Begins</h4>
              <p class="text-gray-600">Exchange of vows and rings in the beautiful garden setting</p>
            </div>
          </div>
          <div class="flex items-start gap-6">
            <div class="bg-sage text-white rounded-full w-16 h-16 flex items-center justify-center font-semibold shadow-lg text-center text-sm">4:45<br/><span class="text-xs">PM</span></div>
            <div class="bg-mist/30 p-5 rounded-lg flex-1">
              <h4 class="font-semibold text-botanical text-lg">Photos &amp; Cocktails</h4>
              <p class="text-gray-600">Enjoy cocktails and appetizers while we capture memories</p>
            </div>
          </div>
          <div class="flex items-start gap-6">
            <div class="bg-sage text-white rounded-full w-16 h-16 flex items-center justify-center font-semibold shadow-lg text-center text-sm">6:30<br/><span class="text-xs">PM</span></div>
            <div class="bg-mist/30 p-5 rounded-lg flex-1">
              <h4 class="font-semibold text-botanical text-lg">Reception Begins</h4>
              <p class="text-gray-600">Grand entrance and first dance at The Grand Ballroom</p>
            </div>
          </div>
          <div class="flex items-start gap-6">
            <div class="bg-sage text-white rounded-full w-16 h-16 flex items-center justify-center font-semibold shadow-lg text-center text-sm">7:30<br/><span class="text-xs">PM</span></div>
            <div class="bg-mist/30 p-5 rounded-lg flex-1">
              <h4 class="font-semibold text-botanical text-lg">Dinner Service</h4>
              <p class="text-gray-600">Three-course gourmet dinner with wine pairing</p>
            </div>
          </div>
          <div class="flex items-start gap-6">
            <div class="bg-sage text-white rounded-full w-16 h-16 flex items-center justify-center font-semibold shadow-lg text-center text-sm">9:00<br/><span class="text-xs">PM</span></div>
            <div class="bg-mist/30 p-5 rounded-lg flex-1">
              <h4 class="font-semibold text-botanical text-lg">Dancing &amp; Celebration</h4>
              <p class="text-gray-600">Live band and DJ – let's party the night away!</p>
            </div>
          </div>
          <div class="flex items-start gap-6">
            <div class="bg-sage text-white rounded-full w-16 h-16 flex items-center justify-center font-semibold shadow-lg text-center text-sm">11:30<br/><span class="text-xs">PM</span></div>
            <div class="bg-mist/30 p-5 rounded-lg flex-1">
              <h4 class="font-semibold text-botanical text-lg">Sparkler Send-Off</h4>
              <p class="text-gray-600">A magical farewell to end the night</p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Important Information -->
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-12">
        <h3 class="font-serif text-4xl font-semibold text-botanical">Important Information</h3>
        <p class="text-gray-600 mt-4">Everything you need to know for our special day</p>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        <div class="flex items-start gap-4 p-5 rounded-lg shadow-sm hover:shadow-lg hover:-translate-y-1 transition-all bg-white">
          <div class="bg-sage/10 p-3 rounded-lg shrink-0">
            <svg class="w-6 h-6 text-sage" fill="currentColor" viewBox="0 0 16 16"><path d="M0 .5A.5.5 0 0 1 .5 0h5a.5.5 0 0 1 .5.5v5.277l4.147-4.131a.5.5 0 0 1 .707 0l3.535 3.536a.5.5 0 0 1 0 .708L10.261 10H15.5a.5.5 0 0 1 .5.5v5a.5.5 0 0 1-.5.5H3a3 3 0 0 1-3-3z"/></svg>
          </div>
          <div>
            <h4 class="font-semibold text-botanical">Dress Code</h4>
            <p class="text-gray-600 text-sm mt-1">Garden Formal / Cocktail Attire. Elegant &amp; garden-inspired colors encouraged</p>
          </div>
        </div>
        <div class="flex items-start gap-4 p-5 rounded-lg shadow-sm hover:shadow-lg hover:-translate-y-1 transition-all bg-white">
          <div class="bg-sage/10 p-3 rounded-lg shrink-0">
            <svg class="w-6 h-6 text-sage" fill="currentColor" viewBox="0 0 16 16"><path d="M2.52 3.515A2.5 2.5 0 0 1 4.82 2h6.362c1 0 1.904.596 2.298 1.515l.792 1.848c.075.175.21.319.38.404.5.25.855.715.965 1.262l.335 1.677c.033.161.049.325.049.49v.413C16 9.06 14.814 10 13.5 10H2.5C1.186 10 0 9.06 0 7.81v-.414c0-.164.016-.328.049-.49l.335-1.676a1.6 1.6 0 0 1 .965-1.263a1.1 1.1 0 0 0 .38-.404z"/><path d="M2.5 11c-.313 0-.616-.033-.908-.096l-.097.543a2.1 2.1 0 0 0 .848 2.07l.882.618A2 2 0 0 0 4.37 14.5h7.26c.415 0 .82-.129 1.146-.366l.882-.617a2.1 2.1 0 0 0 .848-2.07l-.098-.544A5 5 0 0 1 13.5 11z"/></svg>
          </div>
          <div>
            <h4 class="font-semibold text-botanical">Parking</h4>
            <p class="text-gray-600 text-sm mt-1">Complimentary valet service at both venues</p>
          </div>
        </div>
