---
---

<section id="schedule" class="py-20 md:py-24 bg-ivory">
  <div class="max-w-7xl mx-auto px-4">
    <div class="mb-16 text-center">
      <h2 class="font-serif text-4xl md:text-5xl font-light text-botanical mb-6">Wedding Itinerary</h2>
      <div class="w-40 h-0.5 bg-linear-to-r from-transparent via-sage to-transparent mx-auto mt-8"></div>
    </div>

    <div class="max-w-4xl mx-auto space-y-6">
      <!-- Friday -->
      <div class="bg-linear-to-br from-mist to-white border-l-4 border-botanical p-8 shadow-sm">
        <div class="flex flex-col md:flex-row md:items-center md:justify-between mb-6">
          <div>
            <span class="text-sage text-sm uppercase tracking-wider font-semibold">Day 1</span>
            <h3 class="font-serif text-2xl font-semibold text-botanical mt-1">Friday, June 14</h3>
          </div>
          <span class="text-sm text-gray-500 mt-2 md:mt-0">Pre-Wedding Celebration</span>
        </div>
        <div class="space-y-4">
          <div class="flex items-center gap-4 p-4 bg-white/80 rounded-lg">
            <div class="text-botanical font-semibold w-20 shrink-0">7:00 PM</div>
            <div>
              <p class="font-semibold text-botanical">Welcome Dinner</p>
              <p class="text-sm text-gray-500">Riverside Restaurant · Casual Attire</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Saturday -->
      <div class="bg-linear-to-br from-mist to-white border-l-4 border-botanical p-8 shadow-sm">
        <div class="flex flex-col md:flex-row md:items-center md:justify-between mb-6">
          <div>
            <span class="text-sage text-sm uppercase tracking-wider font-semibold">Day 2</span>
            <h3 class="font-serif text-2xl font-semibold text-botanical mt-1">Saturday, June 15 – Wedding Day</h3>
          </div>
          <span class="text-sm text-gray-500 mt-2 md:mt-0">The Big Day!</span>
        </div>
        <div class="space-y-4">
          <div class="flex items-center gap-4 p-4 bg-white/80 rounded-lg">
            <div class="text-botanical font-semibold w-20 shrink-0">4:00 PM</div>
            <div>
              <p class="font-semibold text-botanical">Ceremony</p>
              <p class="text-sm text-gray-500">Rose Garden Estate</p>
            </div>
          </div>
          <div class="flex items-center gap-4 p-4 bg-white/80 rounded-lg">
            <div class="text-botanical font-semibold w-20 shrink-0">5:00 PM</div>
            <div>
              <p class="font-semibold text-botanical">Cocktail Hour</p>
              <p class="text-sm text-gray-500">Garden Terrace</p>
            </div>
          </div>
          <div class="flex items-center gap-4 p-4 bg-white/80 rounded-lg">
            <div class="text-botanical font-semibold w-20 shrink-0">6:30 PM</div>
            <div>
              <p class="font-semibold text-botanical">Reception &amp; Dinner</p>
              <p class="text-sm text-gray-500">The Grand Ballroom</p>
            </div>
          </div>
          <div class="flex items-center gap-4 p-4 bg-white/80 rounded-lg">
            <div class="text-botanical font-semibold w-20 shrink-0">8:30 PM</div>
            <div>
              <p class="font-semibold text-botanical">Dancing &amp; Celebration</p>
              <p class="text-sm text-gray-500">Party all night!</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Sunday -->
      <div class="bg-linear-to-br from-mist to-white border-l-4 border-botanical p-8 shadow-sm">
        <div class="flex flex-col md:flex-row md:items-center md:justify-between mb-6">
          <div>
            <span class="text-sage text-sm uppercase tracking-wider font-semibold">Day 3</span>
            <h3 class="font-serif text-2xl font-semibold text-botanical mt-1">Sunday, June 16</h3>
          </div>
          <span class="text-sm text-gray-500 mt-2 md:mt-0">Post-Wedding</span>
        </div>
        <div class="space-y-4">
          <div class="flex items-center gap-4 p-4 bg-white/80 rounded-lg">
            <div class="text-botanical font-semibold w-20 shrink-0">10:00 AM</div>
            <div>
              <p class="font-semibold text-botanical">Farewell Brunch</p>
              <p class="text-sm text-gray-500">Garden Café · Casual Attire</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
