---
import { useTranslations } from "../i18n";
const t = useTranslations();
---

<section id="schedule" class="py-20 md:py-24 bg-ivory">
  <div class="max-w-7xl mx-auto px-4">
    <div class="mb-16 text-center">
      <h2
        class="font-serif text-4xl md:text-5xl font-light text-botanical mb-6"
      >
        {t("schedule.heading")}
      </h2>
      <div
        class="w-40 h-0.5 bg-linear-to-r from-transparent via-sage to-transparent mx-auto mt-8"
      >
      </div>
    </div>

    <div class="max-w-4xl mx-auto space-y-6">
      {
        t("schedule.days").map((day) => (
          <div class="bg-linear-to-br from-mist to-white border-l-4 border-botanical p-8 shadow-sm">
            <div class="flex flex-col md:flex-row md:items-center md:justify-between mb-6">
              <div>
                <span class="text-sage text-sm uppercase tracking-wider font-semibold">
                  {day.label}
                </span>
                <h3 class="font-serif text-2xl font-semibold text-botanical mt-1">
                  {day.date}
                </h3>
              </div>
              <span class="text-sm text-gray-500 mt-2 md:mt-0">{day.tag}</span>
            </div>
            <div class="space-y-4">
              {day.items.map((item) => (
                <div class="flex items-center gap-4 p-4 bg-white/80 rounded-lg">
                  <div class="text-botanical font-semibold w-20 shrink-0">
                    {item.time}
                  </div>
                  <div>
                    <p class="font-semibold text-botanical">{item.title}</p>
                    <p class="text-sm text-gray-500">{item.note}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
