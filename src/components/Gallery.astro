---
import { useTranslations } from "../i18n";
const t = useTranslations();
const photos = Array.from({ length: 8 }, (_, i) => ({
  src: `/img/gallery${i + 1}.jpg`,
  alt: `${t("gallery.photoAlt")} ${i + 1}`,
}));
---

<section id="gallery" class="py-20 md:py-24 bg-ivory">
  <div class="max-w-7xl mx-auto px-4">
    <div class="mb-16 text-center">
      <h2
        class="font-serif text-4xl md:text-5xl font-light text-botanical mb-6"
      >
        {t("gallery.heading")}
      </h2>
      <div
        class="w-40 h-0.5 bg-linear-to-r from-transparent via-sage to-transparent mx-auto mt-8"
      >
      </div>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
      {
        photos.map((photo) => (
          <div class="relative pb-[100%] overflow-hidden group">
            <a href={photo.src} class="glightbox">
              <img
                src={photo.src}
                alt={photo.alt}
                loading="lazy"
                class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
              />
            </a>
          </div>
        ))
      }
    </div>
  </div>
</section>
