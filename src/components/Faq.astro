---
import { useTranslations } from "../utils/i18n";
const t = useTranslations();
---

<section id="faq" class="py-20 md:py-24 bg-mist relative">
  <div class="max-w-7xl mx-auto px-4 relative">
    <div class="mb-16 text-center">
      <h2
        class="font-serif text-4xl md:text-5xl font-light text-botanical mb-6"
      >
        {t("faq.heading")}
      </h2>
      <div
        class="w-40 h-0.5 bg-linear-to-r from-transparent via-sage to-transparent mx-auto mt-8"
      >
      </div>
    </div>

    <div class="max-w-3xl mx-auto space-y-4" x-data="{ open: null }">
      {
        t("faq.items").map((item, i) => (
          <div class="bg-white shadow-lg border border-mist overflow-hidden">
            <button
              x-on:click={`open = open === ${i} ? null : ${i}`}
              class="w-full flex justify-between items-center p-6 text-left"
            >
              <span class="font-serif text-lg font-semibold text-botanical">
                {item.q}
              </span>
              <svg
                class="w-5 h-5 text-sage transition-transform duration-300 shrink-0 ml-4"
                x-bind:class={`open === ${i} ? 'rotate-180' : ''`}
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M19 9l-7 7-7-7"
                />
              </svg>
            </button>
            <div x-show={`open === ${i}`} x-transition class="px-6 pb-6">
              <p class="text-gray-600 leading-relaxed">{item.a}</p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
